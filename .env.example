# ---- Storage ----
DATA_DIR=./data

# ---- LLM provider (swappable: gemini | anthropic) ----
MODEL_PROVIDER=gemini
GEMINI_API_KEY=...
CLASSIFY_MODEL=gemini-flash-latest
DRAFT_MODEL=gemini-flash-latest
CHAT_MODEL=gemini-flash-latest
# To switch to Groq (fast/free Llama) instead:
# MODEL_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# CLASSIFY_MODEL=llama-3.3-70b-versatile
# DRAFT_MODEL=llama-3.3-70b-versatile
# CHAT_MODEL=llama-3.3-70b-versatile
# To switch to Anthropic instead:
# MODEL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# CLASSIFY_MODEL=claude-haiku-4-5-20251001
# DRAFT_MODEL=claude-sonnet-4-6
# CHAT_MODEL=claude-sonnet-4-6

# ---- Telegram (from @BotFather; chat id from @userinfobot) ----
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=0
TELEGRAM_ENABLED=true   # set false if Telegram is unreachable (ISP block, etc.)

# ---- Gmail OAuth app credentials (GCP Console -> OAuth Client ID, Desktop app) ----
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
# Comma-separated account names; run `uv run python -m app.tools.gmail.auth_setup <name>` for each
GMAIL_ACCOUNTS=personal
GMAIL_PERSONAL_REFRESH_TOKEN=...

# ---- Triage ----
GMAIL_TRIAGE_CRON=0 */6 * * *
GMAIL_TRIAGE_LOOKBACK_HOURS=48
KEY_SENDERS=example.com
EXCLUDED_TOPICS=newsletter, marketing
MAX_EMAILS_PER_RUN=50

# ---- API / dashboard ----
# REQUIRED: rotom refuses to start if this is blank or left as the placeholder
# (an empty token would make the API accept "Bearer " — i.e. unauthenticated).
API_TOKEN=change-me-long-random-string
API_PORT=8000
DASHBOARD_URL=http://localhost:3000

# ---- Locale ----
TIMEZONE=Asia/Kolkata

# ---- Workflows (Inngest) ----
INNGEST_DEV=1
# For docker-compose self-host (optional locally):
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=...

# ---- Drafts / Outreach ----
USER_NAME=Your Name
USER_SIGNATURE=Best,\nYour Name
OUTREACH_ACCOUNT=main
ATTACHMENTS=resume:My Résumé:./data/attachments/resume.pdf
SOUL_FILE=./data/SOUL.md

# "Sent with rotom" email footer. Footer only renders when EMAIL_FOOTER_URL is set.
# EMAIL_FOOTER_ENABLED is the dashboard switch's default state (and the fallback
# for non-dashboard sends).
EMAIL_FOOTER_ENABLED=true
EMAIL_FOOTER_URL=

# ---- Coding agent (GitHub F2) ----
# Requires Docker on the host + gh authenticated with push access to the repos below.
CLAUDE_CODE_OAUTH_TOKEN=
CODING_AGENT_REPOS=          # comma-separated owner/repo allow-list, e.g. DSdatsme/rotom
CODING_AGENT_MAX_TURNS=30
CODING_AGENT_MAX_BUDGET_USD=5
CODING_AGENT_TIMEOUT=1200
CODING_AGENT_MAX_FIX_ROUNDS=2
CODING_AGENT_TEST_CMD=       # optional, e.g. "cd api && uv run pytest -q"
CODING_AGENT_WORKTREE_DIR=data/coding
CODING_AGENT_SANDBOX_IMAGE=rotom-coding:latest
CODING_AGENT_CONTAINER_MEM=4g
CODING_AGENT_CONTAINER_CPUS=2
CODING_AGENT_SANDBOX_NETWORK=    # docker --network for the coder ("" = default/bridge).
                                 # Set "none" to isolate egress where the image pre-bakes
                                 # deps — the only control that contains a leaked OAuth token.
